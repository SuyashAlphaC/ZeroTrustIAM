# ─── Server ───
PORT=4000
NODE_ENV=development
USE_MOCK=true
SEED_DEMO=true        # Set to true ONLY in development to seed alice/bob test users

# ─── Database ───
DB_PATH=./data/iam.db
# DB_VERBOSE=true
BCRYPT_ROUNDS=12

# ─── Risk Scoring ───
RISK_THRESHOLD=0.6
RISK_WEIGHT_DEVICE=0.40
RISK_WEIGHT_LOCATION=0.30
RISK_WEIGHT_TIME=0.20
RISK_WEIGHT_ATTEMPTS=0.10

# ─── Anomaly Detection ───
ANOMALY_WEIGHT=0.15
ANOMALY_THRESHOLD=0.4

# ─── MFA ───
MFA_STEP_UP_THRESHOLD=0.3
MFA_ISSUER=ZeroTrustIAM
MFA_CHALLENGE_EXPIRY_SECONDS=300

# ─── JWT (REQUIRED in production) ───
# JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
# JWT_REFRESH_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=zt-iam-policy-engine

# ─── OAuth / OIDC (REQUIRED in production) ───
OAUTH_ISSUER=http://localhost:4000
OAUTH_CODE_EXPIRY_SECONDS=600
OAUTH_DEFAULT_CLIENT_ID=zt-iam-web
# OAUTH_DEFAULT_CLIENT_SECRET=<generate a strong random secret for production>
OAUTH_CALLBACK_URL=http://localhost:3000/oauth/callback

# ─── WebAuthn ───
WEBAUTHN_RP_NAME=Zero Trust IAM
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
RATE_LIMIT_AUTH_MAX=10

# ─── Logging ───
LOG_LEVEL=info

# ─── Hyperledger Fabric ───
FABRIC_CHANNEL=iamchannel
FABRIC_CHAINCODE=iam-cc
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051

# ─── ZKP ───
ZKP_ENABLED=true

# ─── Cleanup ───
CLEANUP_INTERVAL_MS=300000
